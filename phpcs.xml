<?xml version="1.0"?>
<ruleset name="Vandrekalender Coding Standards">
    <rule ref="WordPress-Extra" />

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="vandrekalender-theme"/>
                <element value="vandrekalender-events"/>
            </property>
        </properties>
    </rule>

    <!-- Allow short array syntax -->
    <rule ref="Universal.Arrays.DisallowShortArraySyntax.Found">
        <severity>0</severity>
    </rule>

    <!-- Allow normal (non-Yoda) conditions -->
    <rule ref="WordPress">
        <exclude name="WordPress.PHP.YodaConditions" />
    </rule>

    <!-- Ignore missing file comment -->
    <rule ref="Squiz.Commenting.FileComment.Missing">
        <severity>0</severity>
    </rule>

    <!-- File names use shorter names intentionally (class-scraper-base vs class-vandrekalender-scraper-base) -->
    <rule ref="WordPress.Files.FileName.InvalidClassFileName">
        <severity>0</severity>
    </rule>

    <!-- meta_query and meta_key are used intentionally for event filtering and deduplication -->
    <rule ref="WordPress.DB.SlowDBQuery">
        <severity>0</severity>
    </rule>

    <arg name="extensions" value="php"/>

    <file>wp-content/themes/vandrekalender-theme</file>
    <file>wp-content/plugins/vandrekalender-events</file>

    <arg value="sp"/>
    <arg name="colors"/>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/public/*</exclude-pattern>
</ruleset>
