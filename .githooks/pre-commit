#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

if [ ! -f "./vendor/bin/phpcs" ]; then
    echo -e "${RED}Error: PHP CodeSniffer not found. Run 'composer install' first.${NC}"
    exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$')

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No PHP files to check.${NC}"
    exit 0
fi

echo -e "${YELLOW}Checking PHP coding standards for staged files...${NC}"

TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

HAS_ERRORS=0
for FILE in $STAGED_FILES; do
    if [ ! -f "$FILE" ]; then
        continue
    fi

    TEMP_FILE="$TEMP_DIR/$(basename $FILE)"
    git show ":$FILE" > "$TEMP_FILE" 2>/dev/null

    if [ $? -ne 0 ]; then
        continue
    fi

    echo "Checking: $FILE"
    ./vendor/bin/phpcs "$TEMP_FILE" --standard=phpcs.xml --report=full

    if [ $? -ne 0 ]; then
        HAS_ERRORS=1
        echo -e "${RED}✗ Violations in: $FILE${NC}"
        echo -e "${YELLOW}  Auto-fix attempt: ./vendor/bin/phpcbf $FILE${NC}"
    else
        echo -e "${GREEN}✓ $FILE${NC}"
    fi
done

if [ $HAS_ERRORS -eq 1 ]; then
    echo -e "${RED}"
    echo "=================================================="
    echo "COMMIT REJECTED — fix coding standard violations"
    echo "  ./vendor/bin/phpcs   — check all"
    echo "  ./vendor/bin/phpcbf  — auto-fix"
    echo "=================================================="
    echo -e "${NC}"
    exit 1
fi

echo -e "${GREEN}All staged PHP files pass standards. ✓${NC}"
exit 0
