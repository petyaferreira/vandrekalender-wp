{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                {
                    "slug": "forest",
                    "color": "#2D5F3F",
                    "name": "Forest"
                },
                {
                    "slug": "fern",
                    "color": "#527A50",
                    "name": "Fern"
                },
                {
                    "slug": "meadow",
                    "color": "#C2D9B0",
                    "name": "Meadow"
                },
                {
                    "slug": "amber",
                    "color": "#D97535",
                    "name": "Amber"
                },
                {
                    "slug": "golden",
                    "color": "#E8B040",
                    "name": "Golden"
                },
                {
                    "slug": "bark",
                    "color": "#7A5230",
                    "name": "Bark"
                },
                {
                    "slug": "cream",
                    "color": "#FAF5EC",
                    "name": "Cream"
                },
                {
                    "slug": "pebble",
                    "color": "#7A7268",
                    "name": "Pebble"
                },
                {
                    "slug": "white",
                    "color": "#FFFFFF",
                    "name": "White"
                },
                {
                    "slug": "charcoal",
                    "color": "#1D1A14",
                    "name": "Charcoal"
                },
                {
                    "slug": "fjord",
                    "color": "#1E6FA5",
                    "name": "Fjord"
                },
                {
                    "slug": "fjord-deep",
                    "color": "#154F78",
                    "name": "Fjord Deep"
                }
            ],
            "link": true
        },
        "layout": {
            "contentSize": "800px",
            "wideSize": "1376px"
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Small 12px",
                    "size": "0.75rem",
                    "slug": "small"
                },
                {
                    "name": "Regular 16px",
                    "size": "1rem",
                    "slug": "regular"
                },
                {
                    "name": "Medium Clamp 12px-24px",
                    "size": "clamp(0.75rem, 1.5vw, 1.5rem)",
                    "slug": "medium-clamp"
                },
                {
                    "name": "Medium 24px",
                    "size": "1.5rem",
                    "slug": "medium"
                },
                {
                    "name": "Large 32px",
                    "size": "clamp(1rem, 2.5vw, 2rem)",
                    "slug": "large"
                },
                {
                    "name": "Extra large 64px",
                    "size": "clamp(2rem, 4vw, 4rem)",
                    "slug": "extra-large"
                }
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fluid": true,
            "fontWeight": false,
            "fontFamilies": [
                {
                    "fontFamily": "Publico, serif",
                    "name": "Publico",
                    "slug": "publico",
                    "fontFace": [
                        {
                            "fontFamily": "Publico",
                            "fontWeight": "300",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/PublicoHeadline-Light.woff2"]
                        },
                        {
                            "fontFamily": "Publico",
                            "fontWeight": "300",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/PublicoHeadline-LightItalic.woff2"]
                        }
                    ]
                },
                {
                    "fontFamily": "Graphik, sans-serif",
                    "name": "Graphik",
                    "slug": "graphik",
                    "fontFace": [
                        {
                            "fontFamily": "Graphik",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/Graphik-Regular.woff2"]
                        },
                        {
                            "fontFamily": "Graphik",
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/Graphik-RegularItalic.woff2"]
                        },
                        {
                            "fontFamily": "Graphik",
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/Graphik-Semibold.woff2"]
                        },
                        {
                            "fontFamily": "Graphik",
                            "fontWeight": "600",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": ["file:./assets/fonts/Graphik-SemiboldItalic.woff2"]
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "name": "2 Extra small",
                    "slug": "2-x-small",
                    "size": "0.625rem",
                    "fluid": false
                },
                {
                    "name": "Extra small",
                    "slug": "x-small",
                    "size": "0.75rem",
                    "fluid": false
                },
                {
                    "name": "Small",
                    "slug": "small",
                    "size": "0.875rem",
                    "fluid": false
                },
                {
                    "name": "Regular",
                    "slug": "regular",
                    "size": "1rem",
                    "fluid": false
                },
                {
                    "name": "Regular Fluid (14px-16px)",
                    "slug": "regular-fluid",
                    "size": "clamp(0.875rem, 3vw, 1rem)"
                },
                {
                    "name": "Medium",
                    "slug": "medium",
                    "size": "1.125rem",
                    "fluid": false
                },
                {
                    "name": "Large",
                    "slug": "large",
                    "size": "1.25rem",
                    "fluid": false
                },
                {
                    "name": "Extra Large",
                    "slug": "extra-large",
                    "size": "1.5rem",
                    "fluid": false
                },
                {
                    "name": "2 Extra Large",
                    "slug": "2-extra-large",
                    "size": "2rem",
                    "fluid": {
                        "min": "1.5rem",
                        "max": "2rem"
                    }
                },
                {
                    "name": "3 Extra Large",
                    "slug": "3-extra-large",
                    "size": "2.5rem",
                    "fluid": {
                        "min": "1.75rem",
                        "max": "2.5rem"
                    }
                },
                {
                    "name": "4 Extra Large",
                    "slug": "4-extra-large",
                    "size": "3rem",
                    "fluid": {
                        "min": "2rem",
                        "max": "3rem"
                    }
                },
                {
                    "name": "5 Extra Large",
                    "slug": "5-extra-large",
                    "size": "3.5rem",
                    "fluid": {
                        "min": "2.25rem",
                        "max": "3.5rem"
                    }
                },
                {
                    "name": "6 Extra Large",
                    "slug": "6-extra-large",
                    "size": "4.5rem",
                    "fluid": {
                        "min": "2.5rem",
                        "max": "4.5rem"
                    }
                }
            ]
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "spacing": {
            "blockGap": "var:preset|spacing|medium",
            "padding": {
                "right": "var:preset|spacing|large",
                "left": "var:preset|spacing|large"
            }
        },
        "css": "& { font-variant-ligatures: no-contextual; }",
        "typography": {
            "fontFamily": "var:preset|font-family|graphik",
            "fontSize": "var:preset|font-size|regular",
            "fontWeight": "400",
            "lineHeight": "1.5"
        },
        "color": {
            "text": "var:preset|color|charcoal",
            "background": "var:preset|color|white"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var:preset|font-family|publico",
                    "fontWeight": "300"
                },
                "color": {
                    "text": "var:preset|color|charcoal"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|5-extra-large",
                    "lineHeight": "1.2"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|4-extra-large",
                    "lineHeight": "1.2"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|3-extra-large",
                    "lineHeight": "1.2"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var:preset|font-size|2-extra-large",
                    "lineHeight": "1.3"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var:preset|font-size|extra-large",
                    "lineHeight": "1.4"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var:preset|font-size|large",
                    "lineHeight": "1.2"
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|fjord"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|fjord-deep"
                    }
                },
                ":active": {
                    "color": {
                        "text": "var:preset|color|fjord-deep"
                    }
                },
                ":focus": {
                    "color": {
                        "text": "var:preset|color|fjord-deep"
                    }
                }
            }
        }
    },
    "customTemplates": [
        {
            "name": "page-with-title",
            "title": "Page (with title)",
            "postTypes": ["page"]
        },
        {
            "name": "page-without-gaps",
            "title": "Page (no gaps)",
            "postTypes": ["page"]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}
