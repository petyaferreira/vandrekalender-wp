{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "useRootPaddingAwareAlignments": true,
    "settings": {
        "appearanceTools": true,
        "color": {
            "palette": [
                {
                    "slug": "forest",
                    "color": "#2D5F3F",
                    "name": "Forest"
                },
                {
                    "slug": "fern",
                    "color": "#527A50",
                    "name": "Fern"
                },
                {
                    "slug": "meadow",
                    "color": "#C2D9B0",
                    "name": "Meadow"
                },
                {
                    "slug": "amber",
                    "color": "#D97535",
                    "name": "Amber"
                },
                {
                    "slug": "golden",
                    "color": "#E8B040",
                    "name": "Golden"
                },
                {
                    "slug": "bark",
                    "color": "#7A5230",
                    "name": "Bark"
                },
                {
                    "slug": "cream",
                    "color": "#FAF5EC",
                    "name": "Cream"
                },
                {
                    "slug": "pebble",
                    "color": "#7A7268",
                    "name": "Pebble"
                },
                {
                    "slug": "white",
                    "color": "#FFFFFF",
                    "name": "White"
                },
                {
                    "slug": "charcoal",
                    "color": "#1D1A14",
                    "name": "Charcoal"
                }
            ]
        },
        "typography": {
            "fluid": true,
            "fontFamilies": [
                {
                    "slug": "sans",
                    "name": "System Sans",
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
                }
            ],
            "fontSizes": [
                { "slug": "small", "size": "0.875rem", "name": "Small" },
                { "slug": "medium", "size": "1rem", "name": "Medium" },
                { "slug": "large", "size": "1.25rem", "name": "Large" },
                { "slug": "x-large", "size": "1.75rem", "name": "X-Large" },
                { "slug": "xx-large", "size": "2.5rem", "name": "XX-Large" }
            ]
        },
        "spacing": {
            "spacingSizes": [
                { "slug": "10", "size": "0.5rem", "name": "XS" },
                { "slug": "20", "size": "1rem", "name": "S" },
                { "slug": "30", "size": "1.5rem", "name": "M" },
                { "slug": "40", "size": "2rem", "name": "L" },
                { "slug": "50", "size": "3rem", "name": "XL" },
                { "slug": "60", "size": "4.5rem", "name": "XXL" }
            ]
        },
        "layout": {
            "contentSize": "760px",
            "wideSize": "1200px"
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--cream)",
            "text": "var(--wp--preset--color--charcoal)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--sans)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.6"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--forest)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--amber)"
                    }
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xx-large)",
                    "fontWeight": "700"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--x-large)",
                    "fontWeight": "600"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--large)",
                    "fontWeight": "600"
                }
            }
        }
    }
}
