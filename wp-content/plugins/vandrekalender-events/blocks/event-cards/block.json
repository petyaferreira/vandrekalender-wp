{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "vandrekalender/event-cards",
    "title": "Event Cards",
    "category": "widgets",
    "description": "Displays matching walking events as a grid of cards.",
    "textdomain": "vandrekalender-events",
    "editorScript": "file:./index.js",
