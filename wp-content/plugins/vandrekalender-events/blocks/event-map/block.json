{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "vandrekalender/event-map",
    "title": "Event Map",
    "category": "widgets",
    "description": "A map of Denmark with a pin for each walking event. Built on Leaflet + OpenStreetMap.",
    "textdomain": "vandrekalender-events",
    "editorScript": "file:./index.js",
    "viewScriptModule": "file:./view.js",
    "style": "file:./style-index.css",
    "render": "file:./render.php",
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "interactivity": true
    }
}
