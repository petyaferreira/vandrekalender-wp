{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "vandrekalender/tabs",
    "version": "1.0.0",
    "title": "Tabs",
    "category": "design",
    "icon": "media-interactive",
    "description": "A tabbed container. Add Tab blocks inside and place any content in each tab.",
    "allowedBlocks": ["vandrekalender/tab"],
    "example": {},
    "supports": {
        "align": ["wide", "full"]
    },
    "attributes": {
        "activeTabId": {
            "type": "string",
            "default": ""
        }
    },
    "providesContext": {
        "vandrekalender/activeTabId": "activeTabId"
    },
    "textdomain": "vandrekalender-events",
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "render": "file:./render.php",
    "viewScript": "file:./view.js"
}
