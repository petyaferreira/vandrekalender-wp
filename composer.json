{
    "name": "petya/vandrekalender",
    "description": "Vandrekalender theme and events plugin",
    "authors": [
        {
            "name": "Petya Ferreira"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        },
        {
            "type": "vcs",
            "url": "https://github.com/djuric/responsive-block-controls"
        }
    ],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/installers": true
        }
    },
    "scripts": {
        "phpcs": "./vendor/bin/phpcs",
        "phpcbf": "./vendor/bin/phpcbf",
        "format": "./node_modules/.bin/prettier --write",
        "setup-hooks": "bash setup-hooks.sh",
        "remove-default-themes": "rm -rf wp-content/themes/twentytwentyfour wp-content/themes/twentytwentythree",
        "post-install-cmd": [
            "@setup-hooks",
            "@remove-default-themes"
        ],
        "post-update-cmd": [
            "@setup-hooks",
            "@remove-default-themes"
        ]
    },
    "require": {
        "composer/installers": "^2.3",
        "wpackagist-theme/twentytwentyfive": "^1.0",
        "wpackagist-plugin/safe-svg": "^2.4",
        "djuric/responsive-block-controls": "^1.2",
        "wpackagist-plugin/seo-by-rank-math": "^1.0",
        "wpackagist-plugin/fluentform": "^6.2",
        "wpackagist-plugin/icon-block": "^2.0"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "extra": {
        "installer-paths": {
            "wp-content/plugins/{$name}/": [
                "type:wordpress-plugin"
            ],
            "wp-content/themes/{$name}/": [
                "type:wordpress-theme"
            ]
        }
    }
}
